{
  "name": "@aspect/os-vfs",
  "version": "0.1.0",
  "description": "Optional virtual file system plugin for AspectOS with adapter-based storage",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aspect/os-core": "*"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "tsup": "^8.0.0",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "license": "MIT"
}
